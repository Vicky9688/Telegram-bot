# ─────────────────────────────────────────────────
# AVIVO Bot — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────

# REQUIRED: Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=paste your telegram bot token here

# Ollama LLM settings (change model here instead of editing code)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistrals

# RAG settings
RAG_TOP_K=3
CHUNK_SIZE=300
CHUNK_OVERLAP=50
